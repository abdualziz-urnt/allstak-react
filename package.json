{
  "name": "@allstak/react",
  "version": "0.1.1",
  "description": "AllStak React SDK — <AllStakErrorBoundary>, useAllStak() hook, withAllStakProfiler HOC. Depends on @allstak/browser.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abdualziz-urnt/allstak-react.git"
  },
  "homepage": "https://allstak.sa",
  "bugs": {
    "url": "https://github.com/abdualziz-urnt/allstak-react/issues"
  },
  "keywords": ["allstak", "observability", "react", "error-boundary"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap --platform browser --external react --external react-dom"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "dependencies": {
    "@allstak/browser": "^0.1.1",
    "allstak-js": "^0.1.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
